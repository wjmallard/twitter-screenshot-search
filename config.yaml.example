screenshot_dir: ~/Desktop/Screenshots
tesseract_workers: 4
commit_batch_size: 50
decay_half_life_days: 30
results_per_page: 10
flask_port: 5000

# MCP semantic search (optional — defaults shown)
embedding_model_id: mlx-community/Qwen3-Embedding-0.6B-4bit-DWQ
embedding_batch_size: 128
embedding_search_limit: 50

# Clustering (optional — defaults shown)
coarse_similarity_floor: 0.15
topic_sim_threshold_pct: 0.30
pca_n_components: 15
time_weight: 2.0
cluster_min_size: 3

# VLM image descriptions (optional — defaults shown)
vlm_model_id: mlx-community/Qwen2.5-VL-7B-Instruct-4bit
vlm_max_tokens: 500
vlm_repetition_penalty: 1.3
